@{
    //ViewBag.TotalExCount
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/AdminLTE/plugins/jQuery/jquery-2.2.3.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style type="text/css">
    /* --- Modern Analytics Dashboard CSS --- */
    #divFirst {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f4f7f6;
        padding: 30px;
        border-radius: 12px;
        min-height: 80vh;
    }

    .dashboard-title {
        color: #2c3e50;
        font-weight: 700;
        margin-bottom: 30px;
        border-bottom: 2px solid #3498db;
        padding-bottom: 10px;
        display: inline-block;
    }

    /* Chart Container Styling - Updated to prevent overflow */
    .chart-container {
        background: #ffffff;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        margin-bottom: 30px;
        height: auto; /* অটো হাইট দেওয়া হলো যাতে ভেতরের কন্টেন্ট অনুযায়ী সাইজ নেয় */
        width: 100%;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .chart-container:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        }

    .chart-title {
        font-size: 16px;
        color: #495057;
        font-weight: 600;
        text-align: center;
        margin-bottom: 20px;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
    }

    /* Dedicated Wrapper for Chart.js to STRICTLY prevent stretching */
    .canvas-wrapper {
        position: relative;
        height: 260px; /* চার্টের জন্য নির্দিষ্ট হাইট */
        width: 100%;
        margin: 0 auto;
    }
</style>

<div class="box-body" id="divFirst">
    <input type="hidden" id="UserRole" data-value="@Session["RoleName"]" />

    <h2 class="dashboard-title"><i class="glyphicon glyphicon-dashboard text-primary"></i> Analytics Overview</h2>

    <div class="row">
        <div class="col-md-6">
            <div class="chart-container">
                <div class="chart-title"><i class="glyphicon glyphicon-stats text-primary"></i> Documentation Status Overview</div>
                <div class="canvas-wrapper">
                    <canvas id="docStatusChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="chart-container">
                <div class="chart-title"><i class="glyphicon glyphicon-warning-sign text-danger"></i> License Expiry Trends</div>
                <div class="canvas-wrapper">
                    <canvas id="expiryTrendChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="chart-container">
                <div class="chart-title"><i class="glyphicon glyphicon-list-alt text-success"></i> Applications by Category</div>
                <div class="canvas-wrapper">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="chart-container">
                <div class="chart-title"><i class="glyphicon glyphicon-send text-info"></i> Monthly Submissions</div>
                <div class="canvas-wrapper">
                    <canvas id="submissionLineChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    $(document).ready(function () {

        try {
            // 1. Documentation Status Overview (Doughnut)
            if (document.getElementById('docStatusChart')) {
                var ctxStatus = document.getElementById('docStatusChart').getContext('2d');
                new Chart(ctxStatus, {
                    type: 'doughnut',
                    data: {
                        labels: ['Approved', 'Pending', 'Rejected'],
                        datasets: [{
                            data: [65, 25, 10],
                            backgroundColor: ['#28a745', '#f39c12', '#dc3545'],
                            borderWidth: 0,
                            hoverOffset: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { position: 'right' } },
                        resizeDelay: 200,
                        cutout: '65%'
                    }
                });
            }

            // 2. License Expiry Trends (Bar)
            if (document.getElementById('expiryTrendChart')) {
                var ctxExpiry = document.getElementById('expiryTrendChart').getContext('2d');
                new Chart(ctxExpiry, {
                    type: 'bar',
                    data: {
                        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                        datasets: [{
                            label: 'Expiring Licenses',
                            data: [5, 12, 8, 20, 15, 30],
                            backgroundColor: 'rgba(0, 86, 179, 0.7)',
                            borderColor: '#0056b3',
                            borderWidth: 1,
                            borderRadius: 6,
                            barPercentage: 0.6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: { beginAtZero: true, grid: { borderDash: [5, 5] } },
                            x: { grid: { display: false } }
                        },
                        resizeDelay: 200
                    }
                });
            }

            // 3. Applications by Category (Pie)
            if (document.getElementById('categoryChart')) {
                var ctxCategory = document.getElementById('categoryChart').getContext('2d');
                new Chart(ctxCategory, {
                    type: 'pie',
                    data: {
                        labels: ['Recipe', 'DTL', 'Product Reg.', 'Price', 'MA Certificate'],
                        datasets: [{
                            data: [30, 20, 25, 15, 10],
                            backgroundColor: ['#007bff', '#6610f2', '#20c997', '#fd7e14', '#e83e8c'],
                            borderWidth: 2,
                            borderColor: '#ffffff',
                            hoverOffset: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { position: 'right' } },
                        resizeDelay: 200
                    }
                });
            }

            // 4. Monthly Submissions (Line)
            if (document.getElementById('submissionLineChart')) {
                var ctxLine = document.getElementById('submissionLineChart').getContext('2d');
                new Chart(ctxLine, {
                    type: 'line',
                    data: {
                        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                        datasets: [{
                            label: 'New Submissions',
                            data: [15, 25, 20, 45, 30, 50],
                            borderColor: '#17a2b8',
                            backgroundColor: 'rgba(23, 162, 184, 0.1)',
                            borderWidth: 3,
                            fill: true,
                            tension: 0.4,
                            pointBackgroundColor: '#ffffff',
                            pointBorderColor: '#17a2b8',
                            pointRadius: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: { beginAtZero: true, grid: { borderDash: [5, 5] } },
                            x: { grid: { display: false } }
                        },
                        resizeDelay: 200,
                        plugins: { legend: { display: false } }
                    }
                });
            }

        } catch (e) {
            console.error("Chart.js initialization error: ", e);
        }

    });
</script>