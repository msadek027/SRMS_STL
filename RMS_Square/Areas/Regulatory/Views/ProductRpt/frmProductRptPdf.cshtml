    function previewFile(url, name, fileId) {
        debugger
    $('#previewTitle').text(name);
    var ext = url.split('.').pop().toLowerCase().split('?')[0];

    // এখানে URL এর সাথে fileId এবং fileName যুক্ত করে দেওয়া হয়েছে
    var streamUrl = '@Url.Action("PreviewFile", "ProductRpt")?fileUrl=' + encodeURIComponent(url)
                  + '&fileId=' + encodeURIComponent(fileId)
                  + '&fileName=' + encodeURIComponent(name);

    if (ext === 'jpg' || ext === 'jpeg' || ext === 'png' || ext === 'gif') {
        $('#previewFrame').hide();
        $('#previewImageHolder').remove();
        $('#previewFrame').after('<div id="previewImageHolder" style="width:100%;height:100%;overflow:auto;display:flex;align-items:center;justify-content:center;padding:16px;"><img src="' + streamUrl + '" style="max-width:100%;max-height:100%;border-radius:4px;box-shadow:0 2px 12px rgba(0,0,0,.15);" /></div>');
    } else {
        $('#previewImageHolder').remove();
        $('#previewFrame').show().attr('src', streamUrl);
    }
    $('#previewModal').css('display', 'flex');
}

function closePreview() {
    $('#previewModal').hide();
    $('#previewFrame').attr('src', '').show();
    $('#previewImageHolder').remove();
}
</script>