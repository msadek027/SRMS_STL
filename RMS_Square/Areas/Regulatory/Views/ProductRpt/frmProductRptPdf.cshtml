   // ── Open Document List Modal ───────────────────────────────────────
    window.openDocList = function(annexId, productName) {
        $('#docListProductName').text(productName);
        $('#docListBody').html('<tr><td colspan="5" style="text-align:center;padding:20px;">Loading files...</td></tr>');
        $('#docListModal').css('display', 'flex');

        $.ajax({
            // আপনার API URL: Regulatory Area এর ProductReg Controller এর GetFilesByAnnexId কল হচ্ছে
            url: '@Url.Action("GetFilesByAnnexId", "ProductRpt", new { area = "Regulatory" })',
            type: 'GET',
            data: { annexId: annexId }, // GetFilesByAnnexId ফাংশন annexId রিসিভ করে
            success: function (files) {
                var tbody = $('#docListBody');
                tbody.empty();

                if (!files || files.length === 0) {
                    tbody.html('<tr><td colspan="5" style="text-align:center;padding:20px;color:#94a3b8;">No files found.</td></tr>');
                    return;
                }

                $.each(files, function (i, f) {
                    var ext = (f.Extention || '').toLowerCase().replace('.', '');
                    var canPreview = ['pdf','jpg','jpeg','png','gif','bmp','webp'].indexOf(ext) >= 0;

                    // ডাউনলোড ইউআরএল
                    var dlUrl = '@Url.Action("Download","General")'
                              + '?path=' + encodeURIComponent((f.FileCode || '') + (f.Extention || ''))
                              + '&fileName=' + encodeURIComponent(f.FileName || '')
                              + '&fileId=' + (f.FileID || '');

                    // প্রিভিউ এর জন্য ডেটা সেট করা
                    var fileUrlForPreview = (f.FileCode || '') + (f.Extention || '');
                    var fileNameForPreview = (f.FileName || 'Document').replace(/'/g, "\\'");

                    // এখানে f.FileID বসিয়ে দেওয়া হলো
                    var fileIdForPreview = f.FileID || '';

                    var actions = '';
                    if (canPreview) {
                        actions += '<a class="btn-icon preview" title="Preview" style="cursor:pointer;margin-right:8px;color:var(--accent);" onclick="previewFile(\'' + fileUrlForPreview + '\',\'' + fileNameForPreview + '\', \'' + fileIdForPreview + '\')"><i class="glyphicon glyphicon-eye-open"></i></a>';
                    }
                    actions += '<a class="btn-icon download" title="Download" style="color:var(--success);" href="' + dlUrl + '" download="' + (f.FileName || 'file') + '" target="_blank"><i class="glyphicon glyphicon-download-alt"></i></a>';

                    tbody.append(
                        '<tr>' +
                        '<td style="color:#64748b;font-weight:600;">' + (i + 1) + '</td>' +
                        '<td>' + (f.RefNo || 'Document') + '</td>' +
                        '<td>' + (f.FileName || '') + '</td>' +
                        '<td>' + (f.FileSize ? f.FileSize + ' MB' : '') + '</td>' +
                        '<td style="text-align:center;">' + actions + '</td>' +
                        '</tr>'
                    );
                });
            },
            error: function () {
                $('#docListBody').html('<tr><td colspan="5" style="text-align:center;padding:20px;color:var(--danger);">Error loading files.</td></tr>');
            }
        });
    };

    window.closeDocList = function() {
        $('#docListModal').hide();
        $('#docListBody').empty();
    };

