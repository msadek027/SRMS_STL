<div id="divLoading" style="margin:0;padding:0;position:fixed;right:0;top:0;width:100%;height:100%; background:rgba(255,255,255,0.7); z-index:30001; display:none; align-items:center; justify-content:center;">
    <div style="background:#fff; padding:20px 30px; border-radius:8px; box-shadow:0 4px 15px rgba(0,0,0,0.1); text-align:center;">
        <img src="~/Content/Images/ajax-loader1.gif" style="margin-bottom:10px;" />
        <p style="margin:0; font-weight:600; color:#4a5568;">Processing...</p>
    </div>
</div>

<script type="text/javascript">
$(document).ready(function () {

    // ── Datepicker ───────────────────────────────────────
    $('.input-group-date input[type="text"]').datepicker({
        format: "dd/mm/yyyy", autoclose: true, todayHighlight: true
    });

    var _allData = [];

    // ── Collect filter params ────────────────────────────
    function collectParams() {
        return {
            CompanyCode: $('#CompanyCode').val(),
            CompanyUnitCode: $('#CompanyUnitCode').val(),
            ProductCode: $('#ProductCode').val(),
            SubFrom: $('#SubFrom').val(),
            SubTo: $('#SubTo').val(),
            ExpFrom: $('#ExpFrom').val(),
            ExpTo: $('#ExpTo').val()
        };
    }

    // ── Render table ─────────────────────────────────────
    function renderTable(data) {
        debugger;
        var tbody = $('#docTableBody');
        tbody.empty();

        if (!data || data.length === 0) {
            $('#docTable').hide();
            $('#emptyState').html('<i class="glyphicon glyphicon-search"></i><p>No records found for the selected criteria.</p>').show();
            $('#statsBar,#resultFooter').hide();
            return;
        }

        var uploaded = 0, pending = 0, expired = 0;
        $.each(data, function (i, r) {
            if (r.DocumentStatus === 'Uploaded') uploaded++;
            else if (r.DocumentStatus === 'Expired') expired++;
            else pending++;
        });

        $('#statTotal').text(data.length);
        $('#statUploaded').text(uploaded);
        $('#statPending').text(pending);
        $('#statExpired').text(expired);
        $('#statsBar').show();

        $.each(data, function (i, r) {
            debugger;
            var badgeCls = r.DocumentStatus === 'Uploaded' ? 'badge-uploaded'
                : r.DocumentStatus === 'Expired' ? 'badge-expired'
                    : 'badge-pending';
            var status = r.DocumentStatus || 'Pending';

            // ── Actions Button Logic ──
            var actions = '';
            if (r.FileCount > 0 || r.FileUrl || r.FileID) {
                actions += '<button class="btn-rpt btn-primary-rpt" style="height:28px;padding:0 12px;font-size:12px;" onclick="openDocList(\'' + r.AnnexId + '\', \'' + (r.ProductName || '').replace(/'/g, "\\'") + '\')">';
                actions += '<i class="glyphicon glyphicon-folder-open"></i> View Files</button>';
            } else {
                actions += '<span style="font-size:11px;color:#aaa;">No file</span>';
            }

            var searchStr = [r.CompanyCode, r.CompanyName, r.CompanyUnitCode, r.CompanyUnitName, r.LicenseNo, r.CompLicenseName, r.RevisionNo, r.SubmissionType].join(' ').toLowerCase();

            tbody.append(
                '<tr data-search="' + [r.CompanyName, r.ProductName, r.BrandName].join(' ').toLowerCase() + '">' +
                '<td style="color:#64748b; font-weight:600;">' + (i + 1) + '</td>' +
                '<td>' + (r.CompanyName || '') + '</td>' +
                '<td>' + (r.CompanyUnitName || '') + '</td>' +
                '<td style="font-weight:600; color:var(--accent-dark);">' + (r.ProductName || '') + '</td>' +
                '<td>' + (r.BrandName || '') + '</td>' +
                '<td>' + (r.Variant || '') + '</td>' +
                '<td>' + (r.PackSizeName || '') + '</td>' +
                '<td>' + (r.InclusionDate || '') + '</td>' +
                '<td>' + (r.DaysLeft !== undefined ? r.DaysLeft : '') + '</td>' +
                '<td style="font-weight:600; color:var(--danger);">' + (r.ValidUptoDate || '') + '</td>' +
                '<td><div class="tbl-actions" style="justify-content:center;">' + actions + '</div></td>' +
                '</tr>'
            );
        });

        $('#emptyState').hide();
        $('#docTable').show();
        $('#resultFooter').show();
        $('#pageInfo').text('Showing ' + data.length + ' record(s)');
    }
    // ── Search ────────────────────────────────────────────
    $('#btnSearch').click(function () {
        debugger
        var params = collectParams();
        $('#divLoading').css('display','flex');

        $.ajax({
            url: '@Url.Action("GetProductReportData", "ProductRpt")',
            type: 'POST',
            contentType: 'application/json',
            dataType: 'json',
            data: JSON.stringify(params),
            success: function (data) {
                debugger
                $('#divLoading').hide();
                if (data && !data.error) {
                    _allData = data;
                    renderTable(data);
                } else {
                    _allData = [];
                    renderTable([]);
                    if (data && data.error) toastr.warning(data.error);
                }
            },
            error: function () {
                $('#divLoading').hide();
                toastr.error('Server error while fetching data.');
            }
        });
    });

    // ── Quick search ─────────────────────────────────────
    $('#txtQuickSearch').on('keyup', function () {
        var val = $(this).val().toLowerCase().trim();
        if (!val) {
            $('#docTableBody tr').show();
        } else {
            $('#docTableBody tr').each(function () {
                var search = $(this).data('search') || '';
                $(this).toggle(search.indexOf(val) !== -1);
            });
        }
    });

    // ── Export ────────────────────────────────────────────
    $('#btnExport').click(function () {
        if (!_allData || _allData.length === 0) {
            toastr.warning('No data to export. Please search first.'); return;
        }
        var params = collectParams();
        params.ReportType = 'EXCEL';

        var form = $('<form method="POST" action="@Url.Action("ExportProductReport", "ProductRpt")" target="_blank" style="display:none;">');
        $.each(params, function(k, v) { form.append('<input type="hidden" name="' + k + '" value="' + v + '">'); });
        $('body').append(form);
        form.submit();
        form.remove();
    });

    // ── Reset ─────────────────────────────────────────────
    $('#btnReset').click(function () {
        $('#CompanyCode, #CompanyName, #CompanyUnitCode, #CompanyUnitName').val('');
        $('#ProductCode, #ProductName, #BrandName, #Variant, #PackSizeName').val('');
        $('#SubFrom, #SubTo, #ExpFrom, #ExpTo').val('');
        $('#txtQuickSearch').val('');

        _allData = [];
        renderTable([]);
        $('#emptyState').html('<i class="glyphicon glyphicon-inbox"></i><p>Select filter criteria and click <strong>Search</strong> to load documents.</p>').show();
        $('#docTable').hide();
    });

    // ── Company popup ─────────────────────────────────────
    var CompanyWindow = $('#CompanyWindow').kendoWindow({
        actions: ['Close'], width:'60%', height:'70%',
        draggable: true, modal: true, title: 'Select Company'
    }).data('kendoWindow').center();

    $('#CompanyWindowGrid').kendoGrid({
        dataSource: new kendo.data.DataSource({ batch: true, pageSize: 10, schema: { model: { id:'CompanyCode' } } }),
        pageable: { pageSizes: true, buttonCount: 5 }, scrollable: true, sortable: true,
        filterable: true, selectable: 'row', height: 380,
        toolbar: [{ template: "<input type='text' id='txtCmpKW' style='float:right' placeholder='Search...' class='form-control'>" }],
        columns: [
            { field:'CompanyName', title:'Company Name', width:180 },
            { field:'CompanyUnitName', title:'Unit Name', width:150 }
        ]
    });

    $('#CompanyName').click(function () {
        CompanyWindow.open().center();
        $.ajax({
            url: '@Url.Action("GetAllCompany", "General")', method:'GET',
            success: function (data) {
                if (data && data.length) {
                    var flatData = [];
                    $.each(data, function(i, c) {
                        if (c.Units && c.Units.length) {
                            $.each(c.Units, function(j, u) {
                                flatData.push({ CompanyCode: c.CompanyCode, CompanyName: c.CompanyName, CompanyUnitCode: u.CompanyUnitCode, CompanyUnitName: u.CompanyUnitName });
                            });
                        } else {
                            flatData.push({ CompanyCode: c.CompanyCode, CompanyName: c.CompanyName, CompanyUnitCode: "", CompanyUnitName: "" });
                        }
                    });
                    $('#CompanyWindowGrid').data('kendoGrid').dataSource.data(flatData);
                }
            }
        });
    });

