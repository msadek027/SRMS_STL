@{
    //ViewBag.Title = "Product Registration - Document Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/AdminLTE/plugins/jQuery/jquery-2.2.3.min.js"></script>
<link href="~/Content/CSS/InputText.css" rel="stylesheet" />

<style>
    /* ── Variables ──────────────────────────────────────── */
    :root {
        --bg: #f0f4f8;
        --surface: #ffffff;
        --surface2: #f7fafc;
        --border: #dde3ec;
        --accent: #1a56db;
        --accent-light: #ebf0ff;
        --accent-dark: #1340b0;
        --success: #0e9f6e;
        --warning: #c27803;
        --danger: #e02424;
        --muted: #6b7280;
        --text: #1a202c;
        --text-light: #4a5568;
        --shadow: 0 1px 4px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.06);
        --radius: 8px;
        --font: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
    }

    .content-header {
        display: none !important;
    }

    body {
        background: var(--bg);
        font-family: var(--font);
        color: var(--text);
    }

    /* ── Page Header ──────────────────────────────────── */
    .rpt-header {
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        padding: 14px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        box-shadow: 0 1px 0 var(--border);
    }

    .rpt-header-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 17px;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -.3px;
    }

        .rpt-header-title .icon-box {
            background: var(--accent);
            color: #fff;
            border-radius: 6px;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
        }

    /* ── Filter Card ──────────────────────────────────── */
    .filter-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        margin: 16px 16px 0;
        overflow: hidden;
    }

    .filter-card-head {
        background: var(--surface2);
        border-bottom: 1px solid var(--border);
        padding: 10px 16px;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: .5px;
        text-transform: uppercase;
        color: var(--accent-dark);
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .filter-card-body {
        padding: 20px;
    }

    /* ── Form rows ────────────────────────────────────── */
    .frow {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 16px;
        align-items: flex-end;
    }

        .frow:last-child {
            margin-bottom: 0;
        }

    .fg {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .fg label {
            font-size: 11px;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .fg .form-control {
            height: 36px;
            border: 1px solid var(--border);
            border-radius: 5px;
            font-size: 13px;
            color: var(--text);
            background: var(--surface);
            transition: border .15s;
            padding: 0 12px;
            width: 100%;
        }

            .fg .form-control:focus {
                outline: none;
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(26,86,219,.1);
            }

            .fg .form-control[readonly] {
                background: #f8fafc;
                cursor: default;
                color: #475569;
                font-weight: 500;
            }

            .fg .form-control.clickable {
                background: #fff;
                cursor: pointer;
                border-color: var(--accent);
            }

    .input-group-date {
        display: flex;
        align-items: center;
    }

        .input-group-date .form-control {
            border-radius: 5px 0 0 5px;
            width: 140px !important;
        }

        .input-group-date .addon {
            height: 36px;
            padding: 0 12px;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-left: none;
            border-radius: 0 5px 5px 0;
            display: flex;
            align-items: center;
            color: var(--accent);
            font-size: 14px;
        }

    /* ── Buttons ──────────────────────────────────────── */
    .btn-rpt {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        height: 36px;
        padding: 0 16px;
        border-radius: 5px;
        font-size: 13px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: background .15s, transform .1s;
    }

        .btn-rpt:active {
            transform: scale(.97);
        }

    .btn-primary-rpt {
        background: var(--accent);
        color: #fff;
    }

        .btn-primary-rpt:hover {
            background: var(--accent-dark);
        }

    .btn-success-rpt {
        background: var(--success);
        color: #fff;
    }

        .btn-success-rpt:hover {
            background: #0a7a56;
        }

    .btn-default-rpt {
        background: var(--surface);
        color: var(--text);
        border: 1px solid var(--border);
    }

        .btn-default-rpt:hover {
            background: var(--surface2);
        }

    /* ── Results Section ──────────────────────────────── */
    .result-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        margin: 16px;
        overflow: hidden;
    }

    .result-head {
        background: var(--surface2);
        border-bottom: 1px solid var(--border);
        padding: 12px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 8px;
    }

    .result-head-title {
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--accent-dark);
        display: flex;
        align-items: center;
        gap: 7px;
    }

    /* ── Document Table ───────────────────────────────── */
    .doc-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .doc-table thead th {
            background: #f1f5fb;
            border-bottom: 2px solid var(--border);
            padding: 10px 12px;
            text-align: left;
            font-size: 11px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            position: sticky;
            top: 0;
            z-index: 1;
        }

        .doc-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .12s;
        }

            .doc-table tbody tr:hover {
                background: var(--accent-light);
            }

        .doc-table tbody td {
            padding: 10px 12px;
            color: var(--text);
            vertical-align: middle;
        }

    .doc-table-wrap {
        max-height: 500px;
        overflow-y: auto;
    }

    /* ── Empty state ──────────────────────────────────── */
    .empty-state {
        padding: 60px 20px;
        text-align: center;
        color: var(--muted);
    }

        .empty-state i {
            font-size: 38px;
            margin-bottom: 12px;
            display: block;
            opacity: .35;
        }

        .empty-state p {
            font-size: 14px;
            margin: 0;
        }

    /* ── Popup Windows ────────────────────────────────── */
    .PopupWindowLayout {
        position: absolute;
        z-index: 9999;
    }

    .PopUpGrid {
        width: 100%;
        height: 100%;
    }
</style>

