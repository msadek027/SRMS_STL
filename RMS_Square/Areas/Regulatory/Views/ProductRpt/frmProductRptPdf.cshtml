<div class="result-card">
    <div class="result-head">
        <div class="result-head-title">
            <i class="glyphicon glyphicon-th-list"></i> Search Results
        </div>
        <div style="display:flex; gap: 8px;">
            <input type="text" id="txtQuickSearch" class="form-control" style="width:250px;height:32px;" placeholder="Quick Search in grid..." />
        </div>
    </div>

    <div class="doc-table-wrap" id="docTableWrap">
        <div class="empty-state" id="emptyState">
            <i class="glyphicon glyphicon-inbox"></i>
