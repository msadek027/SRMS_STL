@{
    //ViewBag.Title = "Product Registration - Document Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/AdminLTE/plugins/jQuery/jquery-2.2.3.min.js"></script>
<link href="~/Content/CSS/InputText.css" rel="stylesheet" />
<style>
    /* ── Variables ──────────────────────────────────────── */
    :root {
        --bg: #f0f4f8;
        --surface: #ffffff;
        --surface2: #f7fafc;
        --border: #dde3ec;
        --accent: #1a56db;
        --accent-light: #ebf0ff;
        --accent-dark: #1340b0;
        --success: #0e9f6e;
        --warning: #c27803;
        --danger: #e02424;
        --muted: #6b7280;
        --text: #1a202c;
        --text-light: #4a5568;
        --shadow: 0 1px 4px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.06);
        --radius: 8px;
        --font: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
    }

    body {
        background: var(--bg);
        font-family: var(--font);
        color: var(--text);
    }

    /* ── Page Header ──────────────────────────────────── */
    .rpt-header {
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        padding: 14px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        box-shadow: 0 1px 0 var(--border);
    }

    .rpt-header-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 17px;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -.3px;
    }

        .rpt-header-title .icon-box {
            background: var(--accent);
            color: #fff;
            border-radius: 6px;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
        }

    /* ── Filter Card ──────────────────────────────────── */
    .filter-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        margin: 16px 16px 0;
        overflow: hidden;
    }

    .filter-card-head {
        background: var(--surface2);
        border-bottom: 1px solid var(--border);
        padding: 10px 16px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: .8px;
        text-transform: uppercase;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .filter-card-body {
        padding: 16px;
    }

    /* ── Form rows ────────────────────────────────────── */
    .frow {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 12px;
        align-items: flex-end;
    }

        .frow:last-child {
            margin-bottom: 0;
        }

    .fg {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

        .fg label {
            font-size: 11px;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .fg .form-control {
            height: 34px;
            border: 1px solid var(--border);
            border-radius: 5px;
            font-size: 13px;
            color: var(--text);
            background: var(--surface);
            transition: border .15s;
            padding: 0 10px;
        }

            .fg .form-control:focus {
                outline: none;
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(26,86,219,.1);
            }

            .fg .form-control[readonly] {
                background: var(--surface2);
                cursor: pointer;
            }

        .fg.fg-sm .form-control {
            width: 130px;
        }

        .fg.fg-md .form-control {
            width: 200px;
        }

        .fg.fg-lg .form-control {
            width: 260px;
        }

        .fg.fg-xl .form-control {
            width: 320px;
        }

    .input-group-date {
        display: flex;
        align-items: center;
    }

        .input-group-date .form-control {
            border-radius: 5px 0 0 5px;
        }

        .input-group-date .addon {
            height: 34px;
            padding: 0 9px;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-left: none;
            border-radius: 0 5px 5px 0;
            display: flex;
            align-items: center;
            color: var(--muted);
            cursor: pointer;
            font-size: 12px;
        }

    /* ── Buttons ──────────────────────────────────────── */
    .btn-rpt {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        height: 34px;
        padding: 0 14px;
        border-radius: 5px;
        font-size: 13px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: background .15s, transform .1s;
    }

        .btn-rpt:active {
            transform: scale(.97);
        }

    .btn-primary-rpt {
        background: var(--accent);
        color: #fff;
    }

        .btn-primary-rpt:hover {
            background: var(--accent-dark);
        }

    .btn-success-rpt {
        background: var(--success);
        color: #fff;
    }

        .btn-success-rpt:hover {
            background: #0a7a56;
        }

    .btn-default-rpt {
        background: var(--surface);
        color: var(--text);
        border: 1px solid var(--border);
    }

        .btn-default-rpt:hover {
            background: var(--surface2);
        }

    /* ── Results Section ──────────────────────────────── */
    .result-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        margin: 14px 16px 16px;
        overflow: hidden;
    }

    .result-head {
        background: var(--surface2);
        border-bottom: 1px solid var(--border);
        padding: 10px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 8px;
    }

    .result-head-title {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: .8px;
        text-transform: uppercase;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .result-head-right {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    /* ── Document Table ───────────────────────────────── */
    .doc-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .doc-table thead th {
            background: #f1f5fb;
            border-bottom: 2px solid var(--border);
            padding: 9px 12px;
            text-align: left;
            font-size: 11px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .5px;
            white-space: nowrap;
            position: sticky;
            top: 0;
            z-index: 1;
        }

        .doc-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .12s;
        }

            .doc-table tbody tr:hover {
                background: var(--accent-light);
            }

        .doc-table tbody td {
            padding: 9px 12px;
            color: var(--text);
            vertical-align: middle;
        }

            .doc-table tbody td.muted {
                color: var(--muted);
                font-size: 12px;
            }

    .doc-table-wrap {
        max-height: 500px;
        overflow-y: auto;
    }

    /* ── Badges ───────────────────────────────────────── */
    .badge-status {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 2px 9px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
    }

    .badge-uploaded {
        background: #d1fae5;
        color: #065f46;
    }

    .badge-pending {
        background: #fef3c7;
        color: #92400e;
    }

    .badge-expired {
        background: #fee2e2;
        color: #991b1b;
    }

    .badge-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
    }

    /* ── Action Buttons in table ──────────────────────── */
    .tbl-actions {
        display: flex;
        gap: 5px;
    }

    .btn-icon {
        width: 28px;
        height: 28px;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--muted);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 12px;
        transition: all .12s;
        text-decoration: none;
    }

        .btn-icon:hover {
            background: var(--accent);
            color: #fff;
            border-color: var(--accent);
        }

        .btn-icon.download:hover {
            background: var(--success);
            border-color: var(--success);
        }

        .btn-icon.preview:hover {
            background: #7c3aed;
            border-color: #7c3aed;
        }

    /* ── Empty state ──────────────────────────────────── */
    .empty-state {
        padding: 60px 20px;
        text-align: center;
        color: var(--muted);
    }

        .empty-state i {
            font-size: 38px;
            margin-bottom: 12px;
            display: block;
            opacity: .35;
        }

        .empty-state p {
            font-size: 13px;
            margin: 0;
        }

    /* ── Popup Windows ────────────────────────────────── */
    .PopupWindowLayout {
        position: absolute;
        z-index: 9999;
    }

    .PopUpGrid {
        width: 100%;
        height: 100%;
    }

    /* ── Loading ──────────────────────────────────────── */
    #divLoading {
        margin: 0;
        padding: 0;
        position: fixed;
        right: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,.45);
        z-index: 30001;
        display: none;
        align-items: center;
        justify-content: center;
    }

    .loading-box {
        background: #fff;
        border-radius: 10px;
        padding: 24px 36px;
        text-align: center;
        box-shadow: 0 8px 32px rgba(0,0,0,.18);
    }

        .loading-box p {
            margin: 10px 0 0;
            font-size: 13px;
            color: var(--muted);
        }

    /* ── Stats bar ────────────────────────────────────── */
    .stats-bar {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        padding: 12px 16px;
        border-bottom: 1px solid var(--border);
        background: var(--surface2);
    }

    .stat-chip {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--text-light);
    }

        .stat-chip strong {
            font-size: 15px;
            font-weight: 700;
            color: var(--text);
        }

    .stat-sep {
        width: 1px;
        background: var(--border);
        height: 22px;
    }

    /* ── Pagination helper ────────────────────────────── */
    .result-footer {
        padding: 10px 16px;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 8px;
    }

        .result-footer .page-info {
            font-size: 12px;
            color: var(--muted);
        }
</style>

<!-- ══ Page Header ══════════════════════════════════════════════════ -->
<div class="rpt-header">
    <div class="rpt-header-title">
        <div class="icon-box"><i class="glyphicon glyphicon-file"></i></div>
        Product Registration – Document Report
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button id="btnSearch" class="btn-rpt btn-primary-rpt">
            <i class="glyphicon glyphicon-search"></i> Search
        </button>
        <button id="btnExport" class="btn-rpt btn-success-rpt">
            <i class="glyphicon glyphicon-download-alt"></i> Export Excel
        </button>
        <button id="btnReset" class="btn-rpt btn-default-rpt">
            <i class="glyphicon glyphicon-refresh"></i> Reset
        </button>
    </div>
</div>

<!-- ══ Filter Card ══════════════════════════════════════════════════ -->
<div class="filter-card">
    <div class="filter-card-head">
        <i class="glyphicon glyphicon-filter"></i> Filter / Search Criteria
    </div>
    <div class="filter-card-body">

        <!-- Row 1 : Company & Product -->
        <div class="frow">
            <div class="fg fg-xl">
                <label>Company</label>
                <div style="display:flex;gap:0;">
                    <input type="text" id="CompanyName" class="form-control" style="border-radius:5px 0 0 5px;width:240px;" placeholder="Press Search to Select" readonly />
                    <input type="hidden" id="CompanyCode" />
                    <button id="btnCompanyFind" class="btn-rpt btn-primary-rpt" style="border-radius:0 5px 5px 0;height:34px;">
                        <i class="glyphicon glyphicon-search"></i>
                    </button>
                </div>
            </div>
            <div class="fg fg-xl">
                <label>Product / Brand</label>
                <div style="display:flex;gap:0;">
                    <input type="text" id="BrandName" class="form-control" style="border-radius:5px 0 0 5px;width:240px;" placeholder="Press Search to Select" readonly />
                    <input type="hidden" id="ProductCodeList" />
                    <input type="hidden" id="ProductCode" />
                    <button id="btnProductFind" class="btn-rpt btn-primary-rpt" style="border-radius:0 5px 5px 0;height:34px;">
                        <i class="glyphicon glyphicon-search"></i>
                    </button>
                </div>
            </div>
            <div class="fg fg-sm">
                <label>Authority Type</label>
                <select id="fAuthType" class="form-control">
                    <option value="">All</option>
                    <option value="A">A</option>
                    <option value="B">B</option>
                    <option value="C">C</option>
                    <option value="D">D</option>
                </select>
            </div>
            <div class="fg fg-md">
                <label>Document Type</label>
                <select id="fDocType" class="form-control">
                    <option value="">All</option>
                    <option value="A">A</option>
                    <option value="B">B</option>
                    <option value="C">C</option>
                    <option value="D">D</option>
                </select>
            </div>
        </div>

        <!-- Row 2 : Dates & Status -->
        <div class="frow">
            <div class="fg fg-md">
                <label>Valid From Date</label>
                <div class="input-group-date">
                    <input type="text" class="form-control" id="ValidFrom" placeholder="dd/mm/yyyy" style="width:130px;" />
                    <span class="addon"><i class="glyphicon glyphicon-th"></i></span>
                </div>
            </div>
            <div class="fg fg-md">
                <label>Valid To Date</label>
                <div class="input-group-date">
                    <input type="text" class="form-control" id="ValidTo" placeholder="dd/mm/yyyy" style="width:130px;" />
                    <span class="addon"><i class="glyphicon glyphicon-th"></i></span>
                </div>
            </div>
            <div class="fg fg-md">
                <label>Submission Date (From)</label>
                <div class="input-group-date">
                    <input type="text" class="form-control" id="SubFrom" placeholder="dd/mm/yyyy" style="width:130px;" />
                    <span class="addon"><i class="glyphicon glyphicon-th"></i></span>
                </div>
            </div>
            <div class="fg fg-md">
                <label>Submission Date (To)</label>
                <div class="input-group-date">
                    <input type="text" class="form-control" id="SubTo" placeholder="dd/mm/yyyy" style="width:130px;" />
                    <span class="addon"><i class="glyphicon glyphicon-th"></i></span>
                </div>
            </div>
            <div class="fg fg-sm">
                <label>Doc Status</label>
                <select id="fDocStatus" class="form-control">
                    <option value="">All</option>
                    <option value="Uploaded">Uploaded</option>
                    <option value="Pending">Pending</option>
                    <option value="Expired">Expired</option>
                </select>
            </div>
        </div>

    </div>
</div>

<!-- ══ Result Card ══════════════════════════════════════════════════ -->
<div class="result-card">
    <div class="result-head">
        <div class="result-head-title">
            <i class="glyphicon glyphicon-th-list"></i>
            Document List
        </div>
        <div class="result-head-right">
            <input type="text" id="txtQuickSearch" class="form-control" style="width:200px;height:30px;font-size:12px;" placeholder="Quick search..." />
        </div>
    </div>

    <!-- Stats bar -->
    <div class="stats-bar" id="statsBar" style="display:none;">
        <div class="stat-chip">Total <strong id="statTotal">0</strong></div>
        <div class="stat-sep"></div>
        <div class="stat-chip" style="color:#065f46;">
            <span style="width:8px;height:8px;border-radius:50%;background:#0e9f6e;display:inline-block;"></span>
            Uploaded <strong id="statUploaded">0</strong>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-chip" style="color:#92400e;">
            <span style="width:8px;height:8px;border-radius:50%;background:#c27803;display:inline-block;"></span>
            Pending <strong id="statPending">0</strong>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-chip" style="color:#991b1b;">
            <span style="width:8px;height:8px;border-radius:50%;background:#e02424;display:inline-block;"></span>
            Expired <strong id="statExpired">0</strong>
        </div>
    </div>

    <!-- Table -->
    <div class="doc-table-wrap" id="docTableWrap">
        <div class="empty-state" id="emptyState">
            <i class="glyphicon glyphicon-inbox"></i>
            <p>Use the filters above and click <strong>Search</strong> to load documents.</p>
        </div>
        <table class="doc-table" id="docTable" style="display:none;">
            <thead>
                <tr>
                    <th style="width:40px;">#</th>
                    <th>Company</th>
                    <th>Product Code</th>
                    <th>Brand / Product</th>
                    <th>Authority Type</th>
                    <th>Authority Name</th>
                    <th>License No</th>
                    <th>Doc Type</th>
                    <th>Doc No</th>
                    <th>Valid Up To</th>
                    <th>Submit Date</th>
                    <th>Status</th>
                    <th style="width:80px;text-align:center;">Actions</th>
                </tr>
            </thead>
            <tbody id="docTableBody"></tbody>
        </table>
    </div>

    <!-- Footer -->
    <div class="result-footer" id="resultFooter" style="display:none;">
        <div class="page-info" id="pageInfo"></div>
        <div id="kendoPager"></div>
    </div>
</div>

<!-- ══ Popup Windows ════════════════════════════════════════════════ -->
<div class="row">
    <div id="CompanyWindow" class="PopupWindowLayout" style="display:none;">
        <div id="CompanyWindowGrid" class="PopUpGrid"></div>
    </div>
    <div id="ProductWindow" class="PopupWindowLayout" style="display:none;">
        <div id="ProductWindowGrid" class="PopUpGrid"></div>
    </div>
</div>

<!-- ══ File Preview Modal ═══════════════════════════════════════════ -->
<div id="previewModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;
     background:rgba(0,0,0,.6);z-index:29999;align-items:center;justify-content:center;">
    <div style="background:#fff;border-radius:10px;width:85%;max-width:900px;
                height:85vh;display:flex;flex-direction:column;overflow:hidden;
                box-shadow:0 20px 60px rgba(0,0,0,.3);">
        <div style="padding:12px 16px;border-bottom:1px solid var(--border);
                    display:flex;align-items:center;justify-content:space-between;">
            <strong id="previewTitle" style="font-size:14px;"></strong>
            <button onclick="closePreview()" class="btn-icon" style="width:32px;height:32px;font-size:15px;">
                <i class="glyphicon glyphicon-remove"></i>
            </button>
        </div>
        <div style="flex:1;overflow:auto;padding:0;">
            <iframe id="previewFrame" style="width:100%;height:100%;border:none;"></iframe>
        </div>
    </div>
</div>

<!-- ══ Loading ══════════════════════════════════════════════════════ -->
<div id="divLoading" style="display:none;">
    <div class="loading-box">
        <img src="~/Content/Images/ajax-loader1.gif" />
        <p>Please wait...</p>
    </div>
</div>

<script type="text/javascript">
$(document).ready(function () {

    // ── Datepicker ───────────────────────────────────────
    $('.input-group-date input[type="text"]').datepicker({
        format: "dd/mm/yyyy", autoclose: true, todayHighlight: true
    });

    var _allData = [];

    // ── Collect filter params ────────────────────────────
    function collectParams() {
        return {
            CompanyCode:     $('#CompanyCode').val(),
            ProductCodeList: $('#ProductCodeList').val(),
            AuthorityType:   $('#fAuthType').val(),
            DocumentType:    $('#fDocType').val(),
            ValidFrom:       $('#ValidFrom').val(),
            ValidTo:         $('#ValidTo').val(),
            SubFrom:         $('#SubFrom').val(),
            SubTo:           $('#SubTo').val(),
            DocStatus:       $('#fDocStatus').val()
        };
    }

    // ── Render table ─────────────────────────────────────
    function renderTable(data) {
        var tbody = $('#docTableBody');
        tbody.empty();

        if (!data || data.length === 0) {
            $('#docTable').hide();
            $('#emptyState').html('<i class="glyphicon glyphicon-search"></i><p>No records found for the selected criteria.</p>').show();
            $('#statsBar, #resultFooter').hide();
            return;
        }

        // Stats
        var uploaded = 0, pending = 0, expired = 0;
        $.each(data, function(i, r) {
            if (r.DocumentStatus === 'Uploaded') uploaded++;
            else if (r.DocumentStatus === 'Expired')  expired++;
            else pending++;
        });
        $('#statTotal').text(data.length);
        $('#statUploaded').text(uploaded);
        $('#statPending').text(pending);
        $('#statExpired').text(expired);
        $('#statsBar').show();

        $.each(data, function(i, r) {
            var badgeCls = r.DocumentStatus === 'Uploaded' ? 'badge-uploaded'
                         : r.DocumentStatus === 'Expired'  ? 'badge-expired'
                         : 'badge-pending';
            var status   = r.DocumentStatus || 'Pending';

            var actions = '';
            if (r.FileUrl) {
                actions += '<a class="btn-icon preview" title="Preview" onclick="previewFile(\'' + r.FileUrl + '\',\'' + (r.FileName||'Document') + '\')" href="javascript:void(0)"><i class="glyphicon glyphicon-eye-open"></i></a>';
                actions += '<a class="btn-icon download" title="Download" href="' + r.FileUrl + '" download="' + (r.FileName||'file') + '" target="_blank"><i class="glyphicon glyphicon-download-alt"></i></a>';
            } else {
                actions += '<span style="font-size:11px;color:#aaa;">No file</span>';
            }

            tbody.append(
                '<tr data-search="' + [r.CompanyName,r.ProductCode,r.BrandName,r.AuthorityName,r.LicenseNo,r.DocNo].join(' ').toLowerCase() + '">' +
                '<td class="muted">' + (i+1) + '</td>' +
                '<td><span style="font-weight:600;">' + (r.CompanyCode||'') + '</span><br><small class="muted">' + (r.CompanyName||'') + '</small></td>' +
                '<td class="muted">' + (r.ProductCode||'') + '</td>' +
                '<td><span style="font-weight:600;">' + (r.BrandName||'') + '</span><br><small class="muted">' + (r.GenericStrength||'') + '</small></td>' +
                '<td>' + (r.AuthorityType||'') + '</td>' +
                '<td>' + (r.AuthorityName||'') + '</td>' +
                '<td class="muted">' + (r.LicenseNo||r.AuthorityLicenseNo||'') + '</td>' +
                '<td class="muted">' + (r.DocumentType||'') + '</td>' +
                '<td class="muted">' + (r.DocNo||r.DocumentNo||'') + '</td>' +
                '<td>' + (r.ValidUptoDate||'') + '</td>' +
                '<td class="muted">' + (r.SubmissionDate||'') + '</td>' +
                '<td><span class="badge-status ' + badgeCls + '"><span class="badge-dot"></span>' + status + '</span></td>' +
                '<td><div class="tbl-actions" style="justify-content:center;">' + actions + '</div></td>' +
                '</tr>'
            );
        });

        $('#emptyState').hide();
        $('#docTable').show();
        $('#resultFooter').show();
        $('#pageInfo').text('Showing ' + data.length + ' record(s)');
    }

    // ── Search ────────────────────────────────────────────
    $('#btnSearch').click(function () {
        var params = collectParams();
        $('#divLoading').css('display','flex');

        $.ajax({
            url: '@Url.Action("GetProductReportData", "ProductRpt")',
            type: 'POST',
            contentType: 'application/json',
            dataType: 'json',
            data: JSON.stringify(params),
            success: function (data) {
                $('#divLoading').hide();
                if (data && !data.error) {
                    _allData = data;
                    renderTable(data);
                } else {
                    _allData = [];
                    renderTable([]);
                    if (data && data.error) toastr.warning(data.error);
                }
            },
            error: function () {
                $('#divLoading').hide();
                toastr.error('Server error while fetching data.');
            }
        });
    });

    // ── Quick search ─────────────────────────────────────
    $('#txtQuickSearch').on('keyup', function () {
        var val = $(this).val().toLowerCase().trim();
        if (!val) {
            $('#docTableBody tr').show();
        } else {
            $('#docTableBody tr').each(function () {
                var search = $(this).data('search') || '';
                $(this).toggle(search.indexOf(val) !== -1);
            });
        }
        var visible = $('#docTableBody tr:visible').length;
        $('#pageInfo').text('Showing ' + visible + ' record(s)');
    });

    // ── Export ────────────────────────────────────────────
    $('#btnExport').click(function () {
        if (!_allData || _allData.length === 0) {
            toastr.warning('No data to export. Please search first.'); return;
        }
        var params = collectParams();
        params.ReportType = 'EXCEL';

        // Build a hidden form and POST to ExportProductReport
        var form = $('<form method="POST" action="@Url.Action("ExportProductReport", "ProductRpt")" target="_blank" style="display:none;">');
        $.each(params, function(k, v) { form.append('<input type="hidden" name="' + k + '" value="' + v + '">'); });
        $('body').append(form);
        form.submit();
        form.remove();
    });

    // ── Reset ─────────────────────────────────────────────
    $('#btnReset').click(function () {
        $('#CompanyCode,#CompanyName,#BrandName,#ProductCodeList,#ProductCode,#ValidFrom,#ValidTo,#SubFrom,#SubTo').val('');
        $('#fAuthType,#fDocType,#fDocStatus').val('');
        $('#txtQuickSearch').val('');
        _allData = [];
        renderTable([]);
        $('#statsBar').hide();
        $('#emptyState').html('<i class="glyphicon glyphicon-inbox"></i><p>Use the filters above and click <strong>Search</strong> to load documents.</p>').show();
        $('#docTable').hide();
        $('#resultFooter,#statsBar').hide();
    });

    // ── Company popup ─────────────────────────────────────
    var CompanyWindow = $('#CompanyWindow').kendoWindow({
        actions: ['Minimize','Maximize','Close'], width:'90%', height:'80%',
        draggable: true, modal: true, title: 'List of Company'
    }).data('kendoWindow').center();

    $('#CompanyWindowGrid').kendoGrid({
        dataSource: new kendo.data.DataSource({ batch: true, pageSize: 10, schema: { model: { id:'CompanyCode' } } }),
        pageable: { pageSizes: true, buttonCount: 5 }, scrollable: true, sortable: true,
        filterable: true, selectable: 'row', height: 430,
        toolbar: [{ template: "<input type='text' id='txtCmpKW' style='float:right' placeholder='Search...' class='k-textbox'>" }],
        columns: [
            { field:'CompanyCode', title:'Code',       width:80 },
            { field:'CompanyName', title:'Name',       width:160 },
            { field:'Address',     title:'Address',    width:160 },
            { field:'LicenseNo',   title:'License No', width:90 }
        ]
    });

    $('#btnCompanyFind').click(function () {
        CompanyWindow.open().center();
        $.ajax({
            url: '@Url.Action("GetAllCompany", "General")', method:'GET',
            success: function (data) {
                if (data && data.length) {
                    $('#CompanyWindowGrid').data('kendoGrid').dataSource.data(data);
                } else { CompanyWindow.close(); }
            }
        });
    });

    $('#CompanyWindowGrid').dblclick(function () {
        var g = $(this).data('kendoGrid'), row = g.dataItem(g.select());
        if (row) {
            $('#CompanyCode').val(row.CompanyCode);
            $('#CompanyName').val(row.CompanyName);
            $('#BrandName,#ProductCodeList,#ProductCode').val('');
        }
        CompanyWindow.close();
    });

    $('#CompanyWindow').on('keyup','#txtCmpKW', function(){
        var v=$(this).val();
        $('#CompanyWindowGrid').data('kendoGrid').dataSource.filter({
            logic:'or', filters:[
                {field:'CompanyCode',operator:'contains',value:v},
                {field:'CompanyName',operator:'contains',value:v}
            ]
        });
    });

    // ── Product popup ─────────────────────────────────────
    var ProductWindow = $('#ProductWindow').kendoWindow({
        actions: ['Minimize','Maximize','Close'], width:'90%', height:'80%',
        draggable: true, modal: true, title: 'List of Product'
    }).data('kendoWindow').center();

    $('#ProductWindowGrid').kendoGrid({
        dataSource: new kendo.data.DataSource({ batch: true, pageSize: 10, schema: { model: { id:'ProductCode' } } }),
        pageable: { pageSizes: true, buttonCount: 5 }, scrollable: true, sortable: true,
        filterable: true, selectable: 'row', height: 430,
        toolbar: [{ template: "<input type='text' id='txtPrdKW' style='float:right' placeholder='Search...' class='k-textbox'>" }],
        columns: [
            { field:'IsSelect',       title:'', filterable:false, template:"<input type='checkbox' value='#=ProductCode#' class='chkProduct' />", width:40, attributes:{style:'text-align:center'} },
            { field:'ProductCode',    title:'Code',        width:100 },
            { field:'BrandName',      title:'Brand Name',  width:130 },
            { field:'GenericStrength',title:'Generic',     width:180 },
            { field:'PackSize',       title:'Pack Size',   width:90 },
            { field:'DosageForm',     title:'Dosage',      width:100 },
            { field:'DarNo',          title:'DAR No',      width:100 }
        ]
    });

    $('#btnProductFind').click(function () {
        var cc = $('#CompanyCode').val();
        if (!cc) { toastr.warning('Please select a company first.'); return; }
        ProductWindow.open().center();
        $.ajax({
            url: '@Url.Action("GetProductFromAnnex", "ProductInfo")',
            type:'GET', data:{ companyCode: cc },
            success: function (data) {
                if (data && data.length) {
                    $('#ProductWindowGrid').data('kendoGrid').dataSource.data(data);
                } else { ProductWindow.close(); }
            }
        });
    });

    $('#ProductWindowGrid').dblclick(function () {
        var checked = $('.chkProduct:checked');
        if (checked.length > 0) {
            var list = [];
            checked.each(function(){ list.push("'" + $(this).val() + "'"); });
            $('#ProductCodeList').val(list.join(','));
            $('#BrandName').val(checked.length + ' Product(s) Selected');
        } else {
            var g = $(this).data('kendoGrid'), row = g.dataItem(g.select());
            if (row) {
                $('#ProductCodeList').val("'" + row.ProductCode + "'");
                $('#BrandName').val(row.BrandName);
            }
        }
        ProductWindow.close();
    });

    $('#ProductWindow').on('keyup','#txtPrdKW', function(){
        var v=$(this).val();
        $('#ProductWindowGrid').data('kendoGrid').dataSource.filter({
            logic:'or', filters:[
                {field:'ProductCode',    operator:'contains',value:v},
                {field:'BrandName',      operator:'contains',value:v},
                {field:'GenericStrength',operator:'contains',value:v},
                {field:'DarNo',          operator:'contains',value:v}
            ]
        });
    });

});

// ── File Preview ─────────────────────────────────────
function previewFile(url, name) {
    $('#previewTitle').text(name);
    $('#previewFrame').attr('src', url);
    $('#previewModal').css('display','flex');
}
function closePreview() {
    $('#previewModal').hide();
    $('#previewFrame').attr('src','');
        }

</script>

