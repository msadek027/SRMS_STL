@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/AdminLTE/plugins/jQuery/jquery-2.2.3.min.js"></script>
<link href="~/Content/CSS/InputText.css" rel="stylesheet" />
<style>
    /* ── পুরো existing CSS block হুবহু copy করুন (ProductRpt থেকে) ── */
    :root {
        --bg: #f0f4f8;
        --surface: #ffffff;
        --surface2: #f7fafc;
        --border: #dde3ec;
        --accent: #1a56db;
        --accent-light: #ebf0ff;
        --accent-dark: #1340b0;
        --success: #0e9f6e;
        --warning: #c27803;
        --danger: #e02424;
        --muted: #6b7280;
        --text: #1a202c;
        --text-light: #4a5568;
        --shadow: 0 1px 4px rgba(0,0,0,.08),0 4px 16px rgba(0,0,0,.06);
        --radius: 8px;
        --font: 'Segoe UI','Helvetica Neue',Arial,sans-serif;
    }

    body {
        background: var(--bg);
        font-family: var(--font);
        color: var(--text);
    }

    .rpt-header {
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        padding: 14px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
    }

    .rpt-header-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 17px;
        font-weight: 700;
        color: var(--text);
    }

        .rpt-header-title .icon-box {
            background: var(--accent);
            color: #fff;
            border-radius: 6px;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
        }

    .filter-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        margin: 16px 16px 0;
        overflow: hidden;
    }

    .filter-card-head {
        background: var(--surface2);
        border-bottom: 1px solid var(--border);
        padding: 10px 16px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: .8px;
        text-transform: uppercase;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .filter-card-body {
        padding: 16px;
    }

    .frow {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 12px;
        align-items: flex-end;
        width: 100%; /* ← full width নেবে */
    }

        .frow:last-child {
            margin-bottom: 0;
        }

    .fg {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

        .fg label {
            font-size: 11px;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .fg .form-control {
            height: 34px;
            border: 1px solid var(--border);
            border-radius: 5px;
            font-size: 13px;
            color: var(--text);
            background: var(--surface);
            transition: border .15s;
            padding: 0 10px;
            width: 100%; /* ← fixed width এর বদলে 100% */
            box-sizing: border-box;
        }

            .fg .form-control:focus {
                outline: none;
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(26,86,219,.1);
            }

            .fg .form-control[readonly] {
                background: var(--surface2);
                cursor: pointer;
            }

        .fg.fg-sm .form-control {
            width: 130px;
        }

        .fg.fg-md .form-control {
            width: 200px;
        }

        .fg.fg-lg .form-control {
            width: 260px;
        }

        .fg.fg-xl .form-control {
            width: 320px;
        }

    .input-group-date {
        display: flex;
        align-items: center;
    }

        .input-group-date .form-control {
            border-radius: 5px 0 0 5px;
        }

        .input-group-date .addon {
            height: 34px;
            padding: 0 9px;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-left: none;
            border-radius: 0 5px 5px 0;
            display: flex;
            align-items: center;
            color: var(--muted);
            cursor: pointer;
            font-size: 12px;
        }

    .btn-rpt {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        height: 34px;
        padding: 0 14px;
        border-radius: 5px;
        font-size: 13px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: background .15s,transform .1s;
    }

        .btn-rpt:active {
            transform: scale(.97);
        }

    .btn-primary-rpt {
        background: var(--accent);
        color: #fff;
    }

        .btn-primary-rpt:hover {
            background: var(--accent-dark);
        }

    .btn-success-rpt {
        background: var(--success);
        color: #fff;
    }

        .btn-success-rpt:hover {
            background: #0a7a56;
        }

    .btn-default-rpt {
        background: var(--surface);
        color: var(--text);
        border: 1px solid var(--border);
    }

        .btn-default-rpt:hover {
            background: var(--surface2);
        }

    .result-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        margin: 14px 16px 16px;
        overflow: hidden;
    }

    .result-head {
        background: var(--surface2);
        border-bottom: 1px solid var(--border);
        padding: 10px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 8px;
    }

    .result-head-title {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: .8px;
        text-transform: uppercase;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .doc-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .doc-table thead th {
            background: #f1f5fb;
            border-bottom: 2px solid var(--border);
            padding: 9px 12px;
            text-align: left;
            font-size: 11px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .5px;
            white-space: nowrap;
            position: sticky;
            top: 0;
            z-index: 1;
        }

        .doc-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .12s;
        }

            .doc-table tbody tr:hover {
                background: var(--accent-light);
            }

        .doc-table tbody td {
            padding: 9px 12px;
            color: var(--text);
            vertical-align: middle;
        }

            .doc-table tbody td.muted {
                color: var(--muted);
                font-size: 12px;
            }

    .doc-table-wrap {
        max-height: 500px;
        overflow-y: auto;
    }

    .badge-status {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 2px 9px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
    }

    .badge-uploaded {
        background: #d1fae5;
        color: #065f46;
    }

    .badge-pending {
        background: #fef3c7;
        color: #92400e;
    }

    .badge-expired {
        background: #fee2e2;
        color: #991b1b;
    }

    .badge-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
    }

    .tbl-actions {
        display: flex;
        gap: 5px;
    }

    .btn-icon {
        width: 28px;
        height: 28px;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--muted);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 12px;
        transition: all .12s;
        text-decoration: none;
    }

        .btn-icon:hover {
            background: var(--accent);
            color: #fff;
            border-color: var(--accent);
        }

        .btn-icon.download:hover {
            background: var(--success);
            border-color: var(--success);
        }

        .btn-icon.preview:hover {
            background: #7c3aed;
            border-color: #7c3aed;
        }

    .empty-state {
        padding: 60px 20px;
        text-align: center;
        color: var(--muted);
    }

        .empty-state i {
            font-size: 38px;
            margin-bottom: 12px;
            display: block;
            opacity: .35;
        }

        .empty-state p {
            font-size: 13px;
            margin: 0;
        }

    .stats-bar {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        padding: 12px 16px;
        border-bottom: 1px solid var(--border);
        background: var(--surface2);
    }

    .stat-chip {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--text-light);
    }

        .stat-chip strong {
            font-size: 15px;
            font-weight: 700;
            color: var(--text);
        }

    .stat-sep {
        width: 1px;
        background: var(--border);
        height: 22px;
    }

    .result-footer {
        padding: 10px 16px;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 8px;
    }

        .result-footer .page-info {
            font-size: 12px;
            color: var(--muted);
        }

    .PopupWindowLayout {
        position: absolute;
        z-index: 9999;
    }

    .PopUpGrid {
        width: 100%;
        height: 100%;
    }

    #divLoading {
        margin: 0;
        padding: 0;
        position: fixed;
        right: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,.45);
        z-index: 30001;
        display: none;
        align-items: center;
        justify-content: center;
    }

    .loading-box {
        background: #fff;
        border-radius: 10px;
        padding: 24px 36px;
        text-align: center;
        box-shadow: 0 8px 32px rgba(0,0,0,.18);
    }

        .loading-box p {
            margin: 10px 0 0;
            font-size: 13px;
            color: var(--muted);
        }
</style>

<!-- ══ Page Header ══════════════════════════════════════════════════ -->
<div class="rpt-header">
    <div class="rpt-header-title">
        <div class="icon-box"><i class="glyphicon glyphicon-certificate"></i></div>
        Company License – Document Report
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button id="btnSearch" class="btn-rpt btn-primary-rpt">
            <i class="glyphicon glyphicon-search"></i> Search
        </button>
        <button id="btnExport" class="btn-rpt btn-success-rpt">
            <i class="glyphicon glyphicon-download-alt"></i> Export Excel
        </button>
        <button id="btnReset" class="btn-rpt btn-default-rpt">
            <i class="glyphicon glyphicon-refresh"></i> Reset
        </button>
    </div>
</div>

