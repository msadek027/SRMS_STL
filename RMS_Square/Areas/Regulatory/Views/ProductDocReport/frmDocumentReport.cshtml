@{
    ViewBag.Title = "Uploaded Documents Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/AdminLTE/plugins/jQuery/jquery-2.2.3.min.js"></script>
<link href="~/Content/CSS/InputText.css" rel="stylesheet" />

<div class="box-header with-border">
    <div class="col-xs-12 col-sm-12 col-md-4 col-lg-4">
        <h3 class="box-title"><i class="glyphicon glyphicon-file"></i> Document Report & Management</h3>
    </div>
    <div class="col-xs-12 col-sm-12 col-md-8 col-lg-8">
        <div style="text-align:right;">
            <button id="btnSearch" class="btn btn-primary btn-lg" type="button">
                <i class="glyphicon glyphicon-search"></i> Search Documents
            </button>
            <button id="btnReset" class="btn btn-default btn-lg" type="button">
                <i class="glyphicon glyphicon-refresh"></i> Reset
            </button>
        </div>
    </div>
</div>

<div class="box-body">
    <fieldset class="panel-border">
        <legend class="panel-border">Search Criteria :</legend>
        <div class="form-group">
            <div class="row">
                <div class="col-sm-2">Company :</div>
                <div class="col-sm-3">
                    <input type="text" id="CompanyName" class="form-control txtBox" placeholder="Double click to select" readonly />
                    <input type="hidden" id="CompanyCode" />
                    <input type="hidden" id="CompanyUnitCode" />
                </div>

                <div class="col-sm-2">Product :</div>
                <div class="col-sm-3">
                    <input type="text" id="ProductName" class="form-control txtBox" placeholder="Double click to select" readonly />
                    <input type="hidden" id="ProductCode" />
                </div>
            </div>
        </div>

        <div class="form-group">
            <div class="row">
                <div class="col-sm-2">Authority Type :</div>
                <div class="col-sm-3">
                    <select id="AuthorityType" class="form-control txtBox">
                        <option value="">-- All --</option>
                        <option value="A">A</option>
                        <option value="B">B</option>
                        <option value="C">C</option>
                        <option value="D">D</option>
                    </select>
                </div>

                <div class="col-sm-2">Document Type :</div>
                <div class="col-sm-3">
                    <select id="DocumentType" class="form-control txtBox">
                        <option value="">-- All --</option>
                        <option value="A">A</option>
                        <option value="B">B</option>
                        <option value="C">C</option>
                        <option value="D">D</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="form-group">
            <div class="row">
                <div class="col-sm-2">Upload Date (From) :</div>
                <div class="col-sm-3">
                    <div class="input-group date">
                        <input type="text" class="form-control txtBox" id="FromDate" placeholder="dd/mm/yyyy">
                        <span class="input-group-addon"><i class="glyphicon glyphicon-th"></i></span>
                    </div>
                </div>
                <div class="col-sm-2">Upload Date (To) :</div>
                <div class="col-sm-3">
                    <div class="input-group date">
                        <input type="text" class="form-control txtBox" id="ToDate" placeholder="dd/mm/yyyy">
                        <span class="input-group-addon"><i class="glyphicon glyphicon-th"></i></span>
                    </div>
                </div>
            </div>
        </div>
    </fieldset>

    <div class="form-group" style="margin-top:15px;">
        <div id="DocumentGrid"></div>
    </div>
</div>

<!-- Popup Windows for Company and Product -->
<div class="row">
    <div id="CompanyWindow" class="PopupWindowLayout" style="display: none;">
        <div id="CompanyWindowGrid" class="PopUpGrid"></div>
    </div>
    <div id="ProductWindow" class="PopupWindowLayout" style="display: none;">
        <div id="ProductWindowGrid" class="PopUpGrid"></div>
    </div>
</div>

<!-- Loading overlay -->
<div id="divLoading" style="margin:0;padding:0;position:fixed;right:0;top:0;width:100%;height:100%;background-color:#666;z-index:30001;opacity:.8;display:none;">
    <p style="position:absolute;top:50%;left:42%;color:White;">Please wait... <img src="~/Content/Images/ajax-loader1.gif"></p>
</div>

<script type="text/javascript">
$(document).ready(function () {
    $('.input-group.date').datepicker({ format: "d/mm/yyyy", autoclose: true, todayHighlight: true });

    // ── Kendo Windows Initializations ────────────────────────────
    var CompanyWindow = $("#CompanyWindow").kendoWindow({
        actions: ["Minimize", "Maximize", "Close"],
        width: "90%", height: "80%", draggable: true, modal: true, title: "Select Company"
    }).data("kendoWindow").center();

    var ProductWindow = $("#ProductWindow").kendoWindow({
        actions: ["Minimize", "Maximize", "Close"],
        width: "90%", height: "80%", draggable: true, modal: true, title: "Select Product"
    }).data("kendoWindow").center();

    // ── Company Grid Logic (Now handles Unit Code) ────────────────
    $("#CompanyName").on('dblclick', function () {
        CompanyWindow.open().center();
        $.get('@Url.Action("GetAllCompany", "General")', function(data) {
            var flatData = [];
            if (data && data.length > 0) {
                $.each(data, function (i, c) {
                    if (c.Units && c.Units.length > 0) {
                        $.each(c.Units, function (j, u) {
                            flatData.push({
                                CompanyCode: c.CompanyCode,
                                CompanyName: c.CompanyName,
                                CompanyUnitCode: u.CompanyUnitCode,
                                CompanyUnitName: u.CompanyUnitName
                            });
                        });
                    } else {
                        flatData.push({
                            CompanyCode: c.CompanyCode,
                            CompanyName: c.CompanyName,
                            CompanyUnitCode: '',
                            CompanyUnitName: ''
                        });
                    }
                });
            }
            $('#CompanyWindowGrid').data('kendoGrid').dataSource.data(flatData);
        });
    });

    $('#CompanyWindowGrid').kendoGrid({
        dataSource: { batch: true, pageSize: 10 },
        pageable: true, scrollable: true, sortable: true, filterable: true, selectable: "row", height: 400,
        columns: [
            { field: "CompanyCode", title: "Comp Code", width: 90 },
            { field: "CompanyName", title: "Company Name", width: 160 },
            { field: "CompanyUnitCode", title: "Unit Code", width: 90 },
            { field: "CompanyUnitName", title: "Unit Name", width: 160 }
        ]
    }).data('kendoGrid');

    $('#CompanyWindowGrid').dblclick(function () {
        var row = $(this).data('kendoGrid').dataItem($(this).data('kendoGrid').select());
        if (row) {
            $('#CompanyCode').val(row.CompanyCode);
            $('#CompanyUnitCode').val(row.CompanyUnitCode);
            // যদি Unit Name থাকে তবে সেটা দেখাবে, না থাকলে Main Company Name দেখাবে
            $('#CompanyName').val(row.CompanyUnitName ? row.CompanyUnitName : row.CompanyName);

            $('#ProductCode, #ProductName').val(''); // Reset product when company changes
        }
        CompanyWindow.close();
    });

   // ── Product Grid Logic (Sending Unit Code to Query) ────────────
    $("#ProductName").on('dblclick', function () {
        // Unit Code নেওয়া হচ্ছে, না থাকলে Main Company Code ফলব্যাক করবে
        var unitCode = $('#CompanyUnitCode').val() || $('#CompanyCode').val();

        if (!unitCode) { toastr.warning("Please select a company first."); return; }

        ProductWindow.open().center();
        // এখন Company Code এর জায়গায় Unit Code ব্যাকএন্ডে যাবে
        $.get('@Url.Action("GetAllActiveProduct", "General")', { companyCode: unitCode }, function(data) {
            $('#ProductWindowGrid').data('kendoGrid').dataSource.data(data);
        });
    });

    $('#ProductWindowGrid').kendoGrid({
        dataSource: { batch: true, pageSize: 10 },
        pageable: true, scrollable: true, sortable: true, filterable: true, selectable: "row", height: 400,
        columns: [
            { field: "ProductCode", title: "Code", width: 100 },
            { field: "ProductName", title: "Product Name", width: 200 },
            { field: "BrandName", title: "Brand", width: 150 }
        ]
    }).data('kendoGrid');

    $('#ProductWindowGrid').dblclick(function () {
        var row = $(this).data('kendoGrid').dataItem($(this).data('kendoGrid').select());
        if (row) {
            $('#ProductCode').val(row.ProductCode);
            $('#ProductName').val(row.ProductName);
        }
        ProductWindow.close();
    });

    // ── Reset ─────────────────────────────────────────────────────
    $('#btnReset').click(function () {
        $('#CompanyCode, #CompanyName, #ProductCode, #ProductName, #AuthorityType, #DocumentType, #FromDate, #ToDate').val('');
        $("#DocumentGrid").data("kendoGrid").dataSource.data([]);
    });

    // ── Main Document Grid ────────────────────────────────────────
    var docGrid = $('#DocumentGrid').kendoGrid({
        dataSource: new kendo.data.DataSource({
            batch: true,
            schema: { model: { id: "FileID" } },
            pageSize: 20
        }),
        pageable: { pageSizes: [20, 50, 100], buttonCount: 5 },
        scrollable: true, sortable: true, filterable: true,
        toolbar: ["excel", { template: "<input type='text' id='txtQuickSearch' style='float:right;width:220px;' placeholder='Quick Search...' class='k-textbox'>" }],
        excel: { fileName: "DocumentList.xlsx", allPages: true },
        height: 500,
        columns: [
            { field: "FileID", hidden: true },
            { field: "FileCode", hidden: true },
            { field: "Extention", hidden: true },
            { field: "CompanyName", title: "Company", width: 140, headerAttributes: { style: "font-weight:bold;" } },
            { field: "ProductName", title: "Product", width: 140, headerAttributes: { style: "font-weight:bold;" } },
            { field: "DocumentName", title: "Doc Type", width: 150, headerAttributes: { style: "font-weight:bold;" } },
            { field: "FileName", title: "File Name", width: 220, headerAttributes: { style: "font-weight:bold;" } },
            { field: "AuthorityName", title: "Authority", width: 120, headerAttributes: { style: "font-weight:bold;" } },
            { field: "UploadDate", title: "Uploaded On", width: 100, headerAttributes: { style: "font-weight:bold;" } },
            { command: [{ name: "Download", text: " Preview", imageClass: "glyphicon glyphicon-eye-open", click: handleDownload }], title: "Action", width: "100px" },
            { command: [{ name: "Delete", text: " Delete", imageClass: "glyphicon glyphicon-trash", click: handleFileDelete }], title: "Action", width: "100px" }
        ]
    }).data('kendoGrid');

    $("#txtQuickSearch").keyup(function () {
        var v = $(this).val();
        docGrid.dataSource.filter({
            logic: "or",
            filters: [
                { field: "ProductName", operator: "contains", value: v },
                { field: "DocumentName", operator: "contains", value: v },
                { field: "FileName", operator: "contains", value: v }
            ]
        });
    });

   // ── Search Documents (Passing Unit Code) ───────────────────────
    $('#btnSearch').click(function () {
        var params = {
            // রিপোর্ট আনার সময়ও Unit Code পাস করছি যাতে ডাটা এক্সাক্টলি ম্যাচ করে
            CompanyCode: $('#CompanyUnitCode').val() || $('#CompanyCode').val(),
            ProductCode: $('#ProductCode').val(),
            AuthorityType: $('#AuthorityType').val(),
            DocumentType: $('#DocumentType').val(),
            FromDate: $('#FromDate').val(),
            ToDate: $('#ToDate').val()
        };

        $("#divLoading").show();
        $.ajax({
            url: '@Url.Action("GetDocumentData", "ProductDocReport")',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(params),
            success: function (data) {
                $("#divLoading").hide();
                if (data && data.length > 0) {
                    docGrid.dataSource.data(data);
                } else {
                    docGrid.dataSource.data([]);
                    toastr.info('No documents found for this criteria.');
                }
            },
            error: function () {
                $("#divLoading").hide();
                toastr.error('Error fetching documents.');
            }
        });
    });

    // ── Grid Action Handlers (Reuse existing logic) ───────────────
    function handleDownload(event) {
        var dataItem = docGrid.dataItem($(event.currentTarget).closest("tr"));
        window.open('@Url.Action("Download", "General")'
            + '?path=' + dataItem.FileCode + dataItem.Extention
            + '&fileName=' + dataItem.FileName
            + '&fileId=' + dataItem.FileID, '_blank');
    }

    function handleFileDelete(event) {
        var dataItem = docGrid.dataItem($(event.currentTarget).closest("tr"));
        if (confirm('Are you sure you want to permanently delete this document?')) {
            $.ajax({
                url: '@Url.Action("DeleteFile", "General")',
                type: 'POST',
                data: JSON.stringify({ "fileId": dataItem.FileID, "fileCode": dataItem.FileCode, "extention": dataItem.Extention }),
                contentType: 'application/json',
                success: function (response) {
                    if (response.Status === "Yes") {
                        toastr.success('Document deleted successfully.');
                        docGrid.dataSource.remove(dataItem);
                    } else {
                        toastr.error('Failed to delete document.');
                    }
                }
            });
        }
    }
});
</script>