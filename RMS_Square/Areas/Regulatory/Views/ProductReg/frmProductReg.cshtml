    // ── Helper: load history for a product ─────────────────────────
    // autoLoadLatest: true  → product select করলে latest record auto-load হবে
    // autoLoadLatest: false → শুধু grid refresh (row click বা save এর পরে)
    function loadHistoryGrid(productCode, companyUnitCode, autoLoadLatest) {
        $.ajax({
            url: '@Url.Action("GetAllInfoByCompany", "ProductReg")',
            type: 'GET',
            data: { companyCode: companyUnitCode },
            success: function (data) {
                // client-side filter by productCode
                var filtered = $.grep(data, function (r) {
                    return r.ProductCode === productCode;
                });

                // sort DESC by AnnexId so latest is first
                filtered.sort(function (a, b) {
                    return parseInt(b.AnnexId) - parseInt(a.AnnexId);
                });

                var historyKGrid = $("#HistoryGrid").data("kendoGrid");
                historyKGrid.dataSource.data(filtered);

                if (filtered.length > 0) {
                    $("#historySection").show();

                    if (autoLoadLatest) {
                        // ── auto-load latest record into detail block ──
                        var latest = filtered[0];
                        loadDetailFromRow(latest);
                        setUpdateMode();

                        // highlight first row in grid
                        historyKGrid.select(historyKGrid.tbody.find("tr:first"));

                        toastr.info('Latest registration record loaded. Click "New Entry" to add a new one.');
                    }
                } else {
                    $("#historySection").hide();
                    // no history → stay in insert mode
                }
            }
        });
    }

