    // ════════════════════════════════════════════════════════════════
    function CheckPagePartAccessPrivilege(status) {
        var state = (status === "" || status == null) ? "New" : status;
        var optA_New = ['<option value="">--Select Any--</option>','<option value="Proposed Annexure">Proposed Annexure</option>','<option value="Proposed Packaging Material">Proposed Packaging Material</option>','<option value="Stability Data">Stability Data</option>','<option value="Approved Annexure">Approved Annexure</option>','<option value="Approved Packaging Material">Approved Packaging Material</option>','<option value="Approval Letter">Approval Letter</option>'];
        var optP_New = ['<option value="">--Select Any--</option>','<option value="Proposed Annexure">Proposed Annexure</option>','<option value="Proposed Packaging Material">Proposed Packaging Material</option>','<option value="Stability Data">Stability Data</option>'];
        var optA_Renew = ['<option value="">--Select Any--</option>','<option value="Proposed Annexure">Proposed Annexure</option>','<option value="Proposed Packaging Material">Proposed Packaging Material</option>','<option value="Approved Annexure">Approved Annexure</option>','<option value="Approved Packaging Material">Approved Packaging Material</option>','<option value="Approval Letter">Approval Letter</option>'];
        var optP_Renew = ['<option value="">--Select Any--</option>','<option value="Proposed Annexure">Proposed Annexure</option>','<option value="Proposed Packaging Material">Proposed Packaging Material</option>'];
        var optA_AnnexAmend = ['<option value="">--Select Any--</option>','<option value="Proposed Annexure">Proposed Annexure</option>','<option value="Stability Data">Stability Data</option>','<option value="Amendment Justification">Amendment Justification</option>','<option value="Approved Annexure">Approved Annexure</option>','<option value="Approved Packaging Material">Approved Packaging Material</option>','<option value="Approval Letter">Approval Letter</option>'];
        var optP_AnnexAmend = ['<option value="">--Select Any--</option>','<option value="Proposed Annexure">Proposed Annexure</option>','<option value="Stability Data">Stability Data</option>','<option value="Amendment Justification">Amendment Justification</option>'];
        var optA_PackAmend = ['<option value="">--Select Any--</option>','<option value="Proposed Packaging Material">Proposed Packaging Material</option>','<option value="Amendment Justification">Amendment Justification</option>','<option value="Approved Annexure">Approved Annexure</option>','<option value="Approved Packaging Material">Approved Packaging Material</option>','<option value="Approval Letter">Approval Letter</option>'];
        var optP_PackAmend = ['<option value="">--Select Any--</option>','<option value="Proposed Packaging Material">Proposed Packaging Material</option>','<option value="Amendment Justification">Amendment Justification</option>'];
        var pageAccess = '@ViewBag.PageAccess';
        if (state === "New")                { $("#RefNo").html(pageAccess === "A" ? optA_New.join('')       : optP_New.join('')); }
        else if (state === "Renew")         { $("#RefNo").html(pageAccess === "A" ? optA_Renew.join('')     : optP_Renew.join('')); }
        else if (state === "Annexure Amendment") { $("#RefNo").html(pageAccess === "A" ? optA_AnnexAmend.join('') : optP_AnnexAmend.join('')); }
        else if (state === "Packaging Amendment") { $("#RefNo").html(pageAccess === "A" ? optA_PackAmend.join('') : optP_PackAmend.join('')); }
    }

