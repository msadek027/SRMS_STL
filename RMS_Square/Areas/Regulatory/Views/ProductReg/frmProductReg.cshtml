            { field: "FileID",    hidden: true },
            { field: "FileCode",  hidden: true },
            { field: "Extention", hidden: true },
            { field: "RefNo",    title: "Document Name", width: 150, headerAttributes: { style: "font-weight:bold;font-size:13px;" } },
            { field: "FileName", title: "File Name",     width: 350, headerAttributes: { style: "font-weight:bold;font-size:13px;" } },
            { field: "FileSize", title: "Size(MB)",      width: 100, filterable: false, headerAttributes: { style: "font-weight:bold;font-size:13px;" } },
            { command: [{ name: "Download", text: "Download", imageClass: "glyphicon glyphicon-download", click: handleDownload }], title: "Download", width: "120px", headerAttributes: { style: "font-weight:bold;font-size:13px;" } },
            { command: [{ name: "Delete",   text: "Delete",   imageClass: "glyphicon glyphicon-trash",    click: handleFileDelete }], title: "Delete", width: "120px", headerAttributes: { style: "font-weight:bold;font-size:13px;" } }
        ]
    }).data('kendoGrid');

    $("#txtInput").keyup(function () {
        var val = $(this).val();
        $("#FileGrid").data("kendoGrid").dataSource.filter({
            logic: "or",
            filters: [
                { field: "RefNo",    operator: "contains", value: val },
                { field: "FileName", operator: "contains", value: val },
                { field: "FileSize", operator: "contains", value: val }
            ]
        });
    });

    function handleFileDelete(event) {
        var dataItemInfo = grid.dataItem($(event.currentTarget).closest("tr"));
        if (confirm('Do you really want to delete this file?')) {
            $.ajax({
                url: '@Url.Action("DeleteFile", "General")',
                type: 'POST',
                data: JSON.stringify({ "fileId": dataItemInfo.FileID, "fileCode": dataItemInfo.FileCode, "extention": dataItemInfo.Extention }),
                contentType: 'application/json; charset=utf-8', dataType: 'json', cache: false,
                success: function (response) {
                    if (response.Status === "Yes") {
                        toastr.success(OperationMsg("FD"));
                        $("#FileGrid").data("kendoGrid").dataSource.remove(dataItemInfo);
                    } else {
                        toastr.error(OperationMsg("FND"));
                    }
                }
            });
        }
    }

    function handleDownload(event) {
        var dataItemInfo = grid.dataItem($(event.currentTarget).closest("tr"));
        window.location.href = '@Url.Action("Download", "General")'
            + '?path=' + dataItemInfo.FileCode + dataItemInfo.Extention
            + '&fileName=' + dataItemInfo.FileName
            + '&fileId=' + dataItemInfo.FileID;
    }

    // ── File upload ─────────────────────────────────────────────────
    $('#UploadFile').on('change', function (e) {
        var checkInput = InputValidation('RefNo');
        if (checkInput === 0) {
            var files  = e.target.files;
            var refId  = $("#AnnexId").val();
            if (refId !== "") {
                var fSizeStrg = "";
                for (var f = 0; f < files.length; f++) {
                    var iSize    = (files[f].size / 1024);
                    var fileSize = Math.round((iSize / 1024) * 100) / 100;
                    fSizeStrg    = fSizeStrg !== "" ? fSizeStrg + ',' + fileSize : fileSize;
                    if (iSize / 1024 > 25) { toastr.warning(OperationMsg("UFW")); $(this).val(''); return; }
                }
                if (files.length > 0 && window.FormData !== undefined) {
                    var data = new FormData();
                    for (var x = 0; x < files.length; x++) { data.append("file" + x, files[x]); }
                    $("#divLoading").show();
                    $.ajax({
                        type: "POST",
                        url: '@Url.Action("UploadFile", "ProductReg")'
                            + '?refLevel1=' + encodeURIComponent(refId)
                            + '&refLevel2='
                            + '&fileSize='  + encodeURIComponent(fSizeStrg)
                            + '&refNo='     + encodeURIComponent($("#RefNo").val()),
                        contentType: false, processData: false, data: data,
                        success: function (result) {
                            $("#divLoading").hide();
                            if (result.msgType === "FUS") {
                                toastr.success(OperationMsg(result.msgType));
                                $("#FileGrid").data("kendoGrid").dataSource.data(result.FileList);
                                $("#ReceivedDate").val(result.ReceiveDate);
                            } else {
                                toastr.warning(OperationMsg(result.msgType));
                            }
                            $('#UploadFile').val('');
                        },
                        error: function (xhr, status, error) {
                            $("#divLoading").hide();
                            toastr.error('Upload failed: ' + error);
                            $('#UploadFile').val('');
                        }
                    });
                }
            } else {
                toastr.warning(OperationMsg("FI"));
                $(this).val('');
            }
        } else {
            toastr.error(OperationMsg("SDN"));
            $(this).val('');
        }
    });

    // ════════════════════════════════════════════════════════════════
    //  SAVE
    //  AnnexId > 0  →  UPDATE
    //  AnnexId = '' →  INSERT  (new entry for same product is fine)
    // ════════════════════════════════════════════════════════════════
    $('#btnSave').click(function () {
        if (changeAny === 1) {
            var checkInput = InputValidation('CompanyCode') + InputValidation('ProductCode');
            if (checkInput === 0) {
                model.AnnexId               = $('#AnnexId').val();
                model.CompanyCode           = $('#CompanyUnitCode').val();
                model.ProductCode           = $('#ProductCode').val();
                model.AnnexureNo            = $('#AnnexureNo').val();
                model.AnnexRevisionNo       = $('#AnnexRevisionNo').val();
                model.StateStatus           = $('#StateStatus').val();
                model.DtlReceivedDate       = $('#DtlReceivedDate').val();
                model.DtlSubmissionDate     = $('#DtlSubmissionDate').val();
                model.DtlApprovalDate       = $('#DtlApprovalDate').val();
                model.DtlRemarks            = $('#DtlRemarks').val();
                model.AuthorityType         = $('#AuthorityType').val();
                model.AuthorityName         = $('#AuthorityName').val();
                model.AuthorityLicenseNo    = $('#AuthorityLicenseNo').val();
                model.AuthorityLicenseName  = $('#AuthorityLicenseName').val();
                model.DocumentType          = $('#DocumentType').val();
                model.DocumentNo            = $('#DocumentNo').val();
                model.ReceivedDate          = $('#ReceivedDate').val();
                model.SubmissionDate        = $('#SubmissionDate').val();
                model.InclusionDate         = $('#InclusionDate').val();
                model.RenewalDate           = $('#RenewalDate').val();
                model.ValidUptoDate         = $('#ValidUptoDate').val();
                model.Remarks               = $('#Remarks').val();

                $.ajax({
                    url: '@Url.Action("frmProductReg", "ProductReg")',
                    data: JSON.stringify(model),
                    type: 'POST',
                    contentType: 'application/json;',
                    dataType: 'json',
                    success: function (data) {
                        if (data.Status === "Yes") {
                            $("#AnnexId").val(data.AnnexId);
                            OperationMsg(data.Mode);
                            changeAny = 0;
                            setUpdateMode(); // after first save, switch to UPDATE mode
                            // Refresh history grid (no auto-load — current record stays loaded)
                            loadHistoryGrid($('#ProductCode').val(), $('#CompanyUnitCode').val(), false);
                        } else {
                            ErrorFrmServerMsg(data.Status);
                        }
                    }
                });
            } else {
                ValidationMsg();
            }
        } else {
            toastr.warning(OperationMsg("NC"));
        }
    });

    var model = {
        "AnnexId": "", "CompanyCode": "", "ProductCode": "", "StateStatus": "",
        "AnnexureNo": "", "AnnexRevisionNo": "",
        "AuthorityType": "", "AuthorityName": "", "AuthorityLicenseNo": "", "AuthorityLicenseName": "",
        "DtlReceivedDate": "", "DtlSubmissionDate": "", "DtlApprovalDate": "", "DtlRemarks": "",
        "DocumentType": "", "DocumentNo": "",
        "ReceivedDate": "", "SubmissionDate": "", "InclusionDate": "",
        "RenewalDate": "", "ValidUptoDate": "", "Remarks": ""
    };

}); // end document.ready
</script>
