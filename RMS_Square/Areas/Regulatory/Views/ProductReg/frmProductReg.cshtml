                if (data && data.length > 0) {
                    var flatData = [];
                    $.each(data, function (i, company) {
                        if (company.Units && company.Units.length > 0) {
                            $.each(company.Units, function (j, unit) {
                                flatData.push({
                                    CompanyCode: company.CompanyCode, CompanyName: company.CompanyName,
                                    Address: company.Address,
                                    CompanyUnitCode: unit.CompanyUnitCode, CompanyUnitName: unit.CompanyUnitName
                                });
                            });
                        } else {
                            flatData.push({ CompanyCode: company.CompanyCode, CompanyName: company.CompanyName,
                                Address: company.Address, CompanyUnitCode: "", CompanyUnitName: "" });
                        }
                    });
                    $('#CompanyWindowGrid').data('kendoGrid').dataSource.data(flatData);
                } else { CompanyWindow.close(); AcknowledgeMsg(); }
            }
        });
    }

