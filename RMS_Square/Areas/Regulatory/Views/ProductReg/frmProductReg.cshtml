<script type="text/javascript">
$(document).ready(function () {

    CheckUnSavedData();
    CheckPagePartAccessPrivilege("");

    // ── Datepickers ─────────────────────────────────────────────────
    $('.input-group.date').datepicker({
        format: "d/mm/yyyy", autoclose: true, todayHighlight: true
    });

    // ════════════════════════════════════════════════════════════════
    //  MODE HELPERS
    // ════════════════════════════════════════════════════════════════
    function setInsertMode() {
        $('#AnnexId').val('');
        $('#modeBadge').removeClass('update').addClass('insert').text('New Entry');
        clearDetailFields();
        $("#RefNo").empty();
        CheckPagePartAccessPrivilege("");
        $("#FileGrid").data("kendoGrid").dataSource.data([]);
    }

    function setUpdateMode() {
        $('#modeBadge').removeClass('insert').addClass('update').text('Edit / Update');
    }


    //===============================
